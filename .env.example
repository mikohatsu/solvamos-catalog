PORT=4173
# Public URL of this catalog site (shown in /api/catalog)
PUBLIC_BASE_URL=http://localhost:4173

# Comma-separated SolVamos Studio /api/catalog origins to aggregate
# Example: https://studio.example.com,http://127.0.0.1:3000
CATALOG_SOURCES=http://127.0.0.1:3000

# Studio / builder link shown in the UI
STUDIO_URL=http://localhost:3000

# Cache TTL for upstream Studio catalog fetches (seconds)
CATALOG_CACHE_TTL_SEC=30
